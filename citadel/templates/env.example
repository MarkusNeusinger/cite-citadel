# No API key needed. Ingest runs through a coding-agent CLI on your existing
# subscription (e.g. a Claude Max plan). Make sure that CLI is installed and
# logged in:
#   claude   (Claude Code)        -> run `claude` once, then /login
#   copilot  (GitHub Copilot CLI)
#   gemini   (Gemini CLI)
#
# The workspace-root .env is auto-loaded (no python-dotenv). Scaffolded by `citadel init`.

# Which CLI ingest shells out to: claude | copilot | gemini   (default: claude)
# Ingest runs the CLI AGENTICALLY: it is pointed at the workspace and edits the wiki page files
# itself (read raw, search wiki, write/merge/split pages), so the CLI needs autonomous file
# tools — claude runs with acceptEdits + a tool allowlist, copilot with --allow-all-tools,
# gemini with --approval-mode yolo. Each backend may be slower on big files; raise
# CITADEL_LLM_TIMEOUT if needed. Run ingest on a clean git working tree so any stray edit shows up.
CITADEL_LLM_CLI=claude

# Model for the claude CLI — an alias (sonnet | opus | haiku) or a full id
# (e.g. claude-sonnet-4-6). copilot/gemini use their own default model.
CITADEL_INGEST_MODEL=sonnet

# Which model imported each raw file is recorded per source in wiki/.citadel_ingested.json and shown
# in the generated provenance catalog wiki/sources/index.md. The recorded label is resolved like:
#   claude  -> "claude:<CITADEL_INGEST_MODEL>" (the model we pass via --model)
#   copilot -> "copilot:<COPILOT_MODEL>" when set (covers a local/Ollama model, e.g.
#              COPILOT_MODEL=qwen3.6:27b), else "copilot:<CITADEL_INGEST_MODEL>" if you exported it,
#              else just "copilot". gemini follows the same rule via GEMINI_MODEL.
# Nothing extra to set for claude; set COPILOT_MODEL/GEMINI_MODEL (or CITADEL_INGEST_MODEL) if you
# want the concrete model id recorded for those backends.

# Optional: override the CLI binary path if it is not on PATH.
# CLAUDE_CODE_PATH=/home/you/.local/bin/claude
# COPILOT_CLI_PATH=/home/you/.local/bin/copilot
# GEMINI_CLI_PATH=/home/you/.npm-global/bin/gemini

# Optional: per-call CLI timeout in seconds (default 1200). Agentic sessions (esp. with
# opus, or large raw files) can run many minutes; raise this if a source times out.
# CITADEL_LLM_TIMEOUT=1200

# Observability — by default the agent session's output is captured only to detect failure and
# then discarded, so there is no record of what the model did (the thing you need when one model
# makes no edits while another does). Two opt-in knobs (also exposed as `citadel ingest` flags):
#   CITADEL_LLM_LOG_DIR  — write one transcript file per source (prompt + full CLI stdout/stderr +
#                      exit code + duration) to this directory. Relative paths resolve under the
#                      workspace root. CLI flag: --log-dir DIR.
#   CITADEL_LLM_VERBOSE  — 1/true to STREAM each session's output to the terminal live, so you can
#                      watch the model work. copilot/gemini show their full agent transcript; the
#                      claude CLI (run with --output-format json) prints only its final result
#                      envelope, so use CITADEL_LLM_LOG_DIR for a full claude record. CLI flag: -v.
# CITADEL_LLM_LOG_DIR=.citadel_llm_logs
# CITADEL_LLM_VERBOSE=0

# Git-repository sources. A sub-folder under raw/ that is a git checkout (holds a .git) — or
# carries an opt-in .citadelsource marker for a git-less snapshot — is ingested as ONE source: a
# size-capped DIGEST of its high-signal files (README, dependency manifests, the connection/
# config layer, the data-transform/pipeline core, entry points; .gitignore honored, lockfiles
# and node_modules/build output dropped) is folded in by a SINGLE agent session. The repo is
# tracked by its HEAD commit, so a later commit re-ingests just the diff. Every external system
# it touches (a database, API, service, or tool like SAP/PLM) gets a `type: System` page under
# wiki/systems/ that accumulates across sources. Set CITADEL_REPO_SUPPORT=0 to fall back to the old
# per-file walk (every file its own source).
# CITADEL_REPO_SUPPORT=1
# Total character budget for one repo digest, and the per-file cap inside it (a long file is
# truncated with a marker). Raise for big repos; lower to keep sessions cheap.
# CITADEL_REPO_DIGEST_MAX_CHARS=120000
# CITADEL_REPO_PER_FILE_MAX_CHARS=8000

# Images. When on (default), a raw file that is a recognized image (screenshot, scan, diagram,
# chart, photo — .png/.jpg/.jpeg/.gif/.bmp/.webp/.tif/.tiff) is handed to the agent to READ
# VISUALLY (the coding-agent CLI's file reader displays images), instead of being rejected as a
# binary. Set to 0 to keep images out of the wiki (they then log as unreadable).
# CITADEL_IMAGE_SUPPORT=1

# Wiki target language (default en). ALL wiki prose, titles, headings, descriptions, and tags are
# written in this language regardless of the raw sources' languages — including a mixed-language
# corpus. Verbatim quotes stay in their original language and proper nouns are never translated
# (the exact conventions live in the rules: schema.md § Wiki language).
# CITADEL_WIKI_LANG=en

# PDF reading mode: text | images (default text). "text" ingests the body text only; "images"
# additionally has the agent LOOK AT the pages' figures, diagrams, and charts and capture what
# they show. The behavior itself lives in the rules (formats/pdf.md); this only names the mode.
# Images mode requires a backend whose file reader renders PDF pages visually (e.g. the claude
# CLI); other backends may silently ingest text only.
# CITADEL_PDF_MODE=text

# Persona/style capture (default 0 = off). When on, first-person sources (interviews, voice-memo
# transcripts, letters, personal emails, diaries) additionally yield the person's opinions and
# preferences as attributed, dated, cited statements plus a per-person style profile backed by
# verbatim cited examples (genres/first-person.md) — enough for an LLM reading the wiki to write
# in that person's voice. Leave off for many-person corpora, where per-document style is noise.
# CITADEL_STYLE_PROFILES=0

# Large-source chunking. A single raw source whose extractable/readable text exceeds this many
# characters is ingested in several sequential agent passes (split on paragraph boundaries), so a
# file too big for one context window still folds in fully — each pass MERGES into the pages the
# earlier passes created. The default ~300000 chars is ~75k tokens (most models fit that); lower it
# for a small-context backend, raise it (or set 0 to disable) for a very large one. PDFs and images
# are never chunked (the agent reads them whole).
# CITADEL_MAX_SOURCE_CHARS=300000

# Same-basename document dedup. When on (default), if several raw files in the SAME folder share a
# basename and are all document-export formats (e.g. report.pptx AND report.pdf), only ONE is
# ingested and the rest are skipped as duplicates (recorded in the failures report, pointing at the
# file kept). Preference is PDF first, then modern Office, then legacy. Set to 0 to ingest every
# format separately.
# CITADEL_DEDUP_BY_BASENAME=1

# OS/junk-file ignore list. System noise a file manager or the OS drops into folders — Windows
# Thumbs.db / desktop.ini, macOS .DS_Store / resource forks, Office ~$ lock files, editor swap &
# backup files — is skipped entirely during the raw/ scan: never ingested, never recorded in the
# manifest or the "could not ingest" catalog. Each pattern is a case-insensitive glob matched
# against a file OR directory basename. A prior run's entries for a now-ignored file are also
# pruned on the next run. Set this to a comma/newline-separated list of globs to REPLACE the
# built-in defaults, or prefix with `+` to ADD to them.
# CITADEL_IGNORE_PATTERNS=+*.bak,~backup*

# Optional path overrides (defaults are the workspace's wiki/, raw/, docs/).
# A RELATIVE value is resolved against the WORKSPACE ROOT (not your shell's CWD), so
# `CITADEL_WIKI_DIR=wiki` always means <workspace>/wiki no matter where you run citadel from.
# An ABSOLUTE value is used as-is, so the wiki/raw can live OUTSIDE the workspace — e.g. on a
# mounted network drive. Keep wiki/ and raw/ under a COMMON parent (as below) so the
# `## Sources` citation links between them stay valid relative links.
# CITADEL_WIKI_DIR=wiki
# CITADEL_RAW_DIR=raw
# CITADEL_DOCS_DIR=docs
#
# Windows mapped network drive (T: -> \\server\share):
# CITADEL_WIKI_DIR=T:\team-wiki\wiki
# CITADEL_RAW_DIR=T:\team-wiki\raw
#
# Linux/macOS mount:
# CITADEL_WIKI_DIR=/mnt/llmwiki/wiki
# CITADEL_RAW_DIR=/mnt/llmwiki/raw
#
# Ingest with the claude or copilot backend when wiki/raw are outside the workspace (claude is
# granted access via --add-dir; copilot via --allow-all-paths).
